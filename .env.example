# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── PostgreSQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_directory
DB_USER=postgres
DB_PASSWORD=your_password_here
# Optional untuk Railway / Supabase / Neon. Jika diisi, DB_* di atas akan diabaikan.
DATABASE_URL=
DB_SSL=false        # set true untuk Railway / Supabase / Neon

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_random_string_minimal_32_karakter
JWT_EXPIRES_IN=7d

# ── Rate Limit ───────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Upload ───────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
